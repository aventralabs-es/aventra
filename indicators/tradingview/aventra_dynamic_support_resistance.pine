//@version=6
// Aventra Version: 1.1.4
indicator("Dynamic Support Resistance [Aventra]", shorttitle="Dynamic Support Resistance [Aventra]", overlay=true, max_lines_count=100, max_labels_count=100, max_boxes_count=100)

calculation_timeframe = input.timeframe("", "Calculation Timeframe")
pivot_left = input.int(5, "Pivot Left Bars", minval=1)
pivot_right = input.int(5, "Pivot Right Bars", minval=1)
max_levels = input.int(8, "Maximum Levels", minval=1, maxval=25)
group_nearby_levels = input.bool(true, "Group Nearby Levels")
zone_atr_length = input.int(14, "Zone ATR Length", minval=1)
zone_tolerance_atr = input.float(0.35, "Zone Tolerance ATR", minval=0.0, step=0.05)
show_zone_midline = input.bool(true, "Show Zone Midline")
show_breakout_labels = input.bool(true, "Show Breakout Labels")
break_label_size = input.string("Tiny", "Break Label Size", options=["Tiny", "Small", "Normal", "Large"])
show_price_labels = input.bool(true, "Show Price Labels")
level_label_size = input.string("Tiny", "Level Label Size", options=["Tiny", "Small", "Normal", "Large"])
resistance_color = input.color(color.new(color.red, 50), "Resistance Color")
support_color = input.color(color.new(color.lime, 50), "Support Color")
line_width = input.int(2, "Line Width", minval=1, maxval=5)

use_chart_timeframe = calculation_timeframe == ""

get_label_size(string _size) =>
    switch _size
        "Tiny" => size.tiny
        "Small" => size.small
        "Normal" => size.normal
        "Large" => size.large
        => size.tiny

level_label_display_size = get_label_size(level_label_size)

calc_pivot_high() =>
    ta.pivothigh(high, pivot_left, pivot_right)

calc_pivot_low() =>
    ta.pivotlow(low, pivot_left, pivot_right)

pivot_high_chart = calc_pivot_high()
pivot_low_chart = calc_pivot_low()
pivot_high = use_chart_timeframe ? pivot_high_chart : request.security(syminfo.tickerid, calculation_timeframe, calc_pivot_high(), barmerge.gaps_on, barmerge.lookahead_off)
pivot_low = use_chart_timeframe ? pivot_low_chart : request.security(syminfo.tickerid, calculation_timeframe, calc_pivot_low(), barmerge.gaps_on, barmerge.lookahead_off)

zone_atr_chart = ta.atr(zone_atr_length)
zone_atr = use_chart_timeframe ? zone_atr_chart : request.security(syminfo.tickerid, calculation_timeframe, ta.atr(zone_atr_length), barmerge.gaps_off, barmerge.lookahead_off)
zone_tolerance = math.max(nz(zone_atr) * zone_tolerance_atr, syminfo.mintick)
zone_padding = math.max(zone_tolerance * 0.08, syminfo.mintick * 2.0)

new_resistance = not na(pivot_high) and na(pivot_high[1])
new_support = not na(pivot_low) and na(pivot_low[1])

var array<line> resistance_lines = array.new<line>()
var array<label> resistance_labels = array.new<label>()
var array<box> resistance_boxes = array.new<box>()
var array<line> resistance_midlines = array.new<line>()
var array<float> resistance_tops = array.new<float>()
var array<float> resistance_bottoms = array.new<float>()
var array<int> resistance_counts = array.new<int>()

var array<line> support_lines = array.new<line>()
var array<label> support_labels = array.new<label>()
var array<box> support_boxes = array.new<box>()
var array<line> support_midlines = array.new<line>()
var array<float> support_tops = array.new<float>()
var array<float> support_bottoms = array.new<float>()
var array<int> support_counts = array.new<int>()

var float nearest_resistance = na
var float nearest_support = na

format_zone_label(string _text, float _top, float _bottom, int _count) =>
    float zone_mid = (_top + _bottom) / 2.0
    string count_text = _count > 1 ? " x" + str.tostring(_count) : ""
    _text + " Zone " + str.tostring(zone_mid, format.mintick) + count_text

find_matching_zone(array<float> _tops, array<float> _bottoms, float _price, float _tolerance) =>
    int match_index = -1
    if array.size(_tops) > 0
        for i = 0 to array.size(_tops) - 1
            float zone_top = array.get(_tops, i)
            float zone_bottom = array.get(_bottoms, i)
            float zone_mid = (zone_top + zone_bottom) / 2.0
            float proposed_top = math.max(zone_top, _price)
            float proposed_bottom = math.min(zone_bottom, _price)
            float proposed_span = proposed_top - proposed_bottom
            bool near_zone = math.abs(_price - zone_mid) <= _tolerance
            bool tight_enough = proposed_span <= _tolerance
            if near_zone and tight_enough
                match_index := i
                break
    match_index

trim_line_levels(array<line> _lines, array<label> _labels) =>
    while array.size(_lines) > max_levels
        line.delete(array.shift(_lines))
    while array.size(_labels) > max_levels
        label.delete(array.shift(_labels))

trim_zone_levels(array<box> _boxes, array<line> _midlines, array<label> _labels, array<float> _tops, array<float> _bottoms, array<int> _counts) =>
    while array.size(_boxes) > max_levels
        box.delete(array.shift(_boxes))
        line.delete(array.shift(_midlines))
        if array.size(_labels) > 0
            label.delete(array.shift(_labels))
        array.shift(_tops)
        array.shift(_bottoms)
        array.shift(_counts)

create_level(array<line> _lines, array<label> _labels, array<box> _boxes, array<line> _midlines, array<float> _tops, array<float> _bottoms, array<int> _counts, float _price, color _color, string _text, bool _is_resistance) =>
    float level_for_break = _price
    if group_nearby_levels
        int match_index = find_matching_zone(_tops, _bottoms, _price, zone_tolerance)
        if match_index >= 0
            float zone_top = math.max(array.get(_tops, match_index), _price)
            float zone_bottom = math.min(array.get(_bottoms, match_index), _price)
            int zone_count = array.get(_counts, match_index) + 1
            float zone_mid = (zone_top + zone_bottom) / 2.0
            float display_top = zone_top + zone_padding
            float display_bottom = zone_bottom - zone_padding
            array.set(_tops, match_index, zone_top)
            array.set(_bottoms, match_index, zone_bottom)
            array.set(_counts, match_index, zone_count)
            box zone_box = array.get(_boxes, match_index)
            line zone_midline = array.get(_midlines, match_index)
            box.set_top(zone_box, display_top)
            box.set_bottom(zone_box, display_bottom)
            box.set_right(zone_box, bar_index)
            box.set_bgcolor(zone_box, color.new(_color, 88))
            box.set_border_color(zone_box, color.new(_color, 100))
            line.set_y1(zone_midline, zone_mid)
            line.set_y2(zone_midline, zone_mid)
            line.set_x2(zone_midline, bar_index)
            line.set_color(zone_midline, show_zone_midline ? _color : color.new(_color, 100))
            if show_price_labels and array.size(_labels) > match_index
                label zone_label = array.get(_labels, match_index)
                label.set_x(zone_label, bar_index)
                label.set_y(zone_label, zone_mid)
                label.set_text(zone_label, format_zone_label(_text, zone_top, zone_bottom, zone_count))
                label.set_color(zone_label, _color)
                label.set_textcolor(zone_label, color.white)
                label.set_size(zone_label, level_label_display_size)
            level_for_break := _is_resistance ? zone_top : zone_bottom
        else
            float zone_top = _price
            float zone_bottom = _price
            float zone_mid = _price
            float display_top = zone_top + zone_padding
            float display_bottom = zone_bottom - zone_padding
            box new_box = box.new(bar_index - pivot_right, display_top, bar_index, display_bottom, extend=extend.right, border_color=color.new(_color, 100), bgcolor=color.new(_color, 88))
            line new_midline = line.new(bar_index - pivot_right, zone_mid, bar_index, zone_mid, extend=extend.right, color=show_zone_midline ? _color : color.new(_color, 100), width=line_width, style=line.style_dotted)
            array.push(_boxes, new_box)
            array.push(_midlines, new_midline)
            array.push(_tops, zone_top)
            array.push(_bottoms, zone_bottom)
            array.push(_counts, 1)
            if show_price_labels
                label new_label = label.new(bar_index, zone_mid, format_zone_label(_text, zone_top, zone_bottom, 1), style=label.style_label_left, color=_color, textcolor=color.white, size=level_label_display_size)
                array.push(_labels, new_label)
            trim_zone_levels(_boxes, _midlines, _labels, _tops, _bottoms, _counts)
            level_for_break := _is_resistance ? zone_top : zone_bottom
    else
        line new_line = line.new(bar_index - pivot_right, _price, bar_index, _price, extend=extend.right, color=_color, width=line_width)
        array.push(_lines, new_line)
        if show_price_labels
            label new_label = label.new(bar_index, _price, _text + " " + str.tostring(_price, format.mintick), style=label.style_label_left, color=_color, textcolor=color.white, size=level_label_display_size)
            array.push(_labels, new_label)
        trim_line_levels(_lines, _labels)
    level_for_break

if new_resistance
    nearest_resistance := create_level(resistance_lines, resistance_labels, resistance_boxes, resistance_midlines, resistance_tops, resistance_bottoms, resistance_counts, pivot_high, resistance_color, "Resistance", true)

if new_support
    nearest_support := create_level(support_lines, support_labels, support_boxes, support_midlines, support_tops, support_bottoms, support_counts, pivot_low, support_color, "Support", false)

if show_price_labels
    if array.size(resistance_labels) > 0
        for i = 0 to array.size(resistance_labels) - 1
            label.set_x(array.get(resistance_labels, i), bar_index)
            label.set_size(array.get(resistance_labels, i), level_label_display_size)
    if array.size(support_labels) > 0
        for i = 0 to array.size(support_labels) - 1
            label.set_x(array.get(support_labels, i), bar_index)
            label.set_size(array.get(support_labels, i), level_label_display_size)

breakout = not na(nearest_resistance) and ta.crossover(close, nearest_resistance)
breakdown = not na(nearest_support) and ta.crossunder(close, nearest_support)

break_label_tiny = break_label_size == "Tiny"
break_label_small = break_label_size == "Small"
break_label_normal = break_label_size == "Normal"
break_label_large = break_label_size == "Large"

plotshape(show_breakout_labels and breakout and break_label_tiny, title="Breakout Signal Tiny", text="Breakout", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 50), textcolor=color.black, size=size.tiny)
plotshape(show_breakout_labels and breakout and break_label_small, title="Breakout Signal Small", text="Breakout", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 50), textcolor=color.black, size=size.small)
plotshape(show_breakout_labels and breakout and break_label_normal, title="Breakout Signal Normal", text="Breakout", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 50), textcolor=color.black, size=size.normal)
plotshape(show_breakout_labels and breakout and break_label_large, title="Breakout Signal Large", text="Breakout", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 50), textcolor=color.black, size=size.large)

plotshape(show_breakout_labels and breakdown and break_label_tiny, title="Breakdown Signal Tiny", text="Breakdown", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 50), textcolor=color.white, size=size.tiny)
plotshape(show_breakout_labels and breakdown and break_label_small, title="Breakdown Signal Small", text="Breakdown", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 50), textcolor=color.white, size=size.small)
plotshape(show_breakout_labels and breakdown and break_label_normal, title="Breakdown Signal Normal", text="Breakdown", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 50), textcolor=color.white, size=size.normal)
plotshape(show_breakout_labels and breakdown and break_label_large, title="Breakdown Signal Large", text="Breakdown", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 50), textcolor=color.white, size=size.large)

alertcondition(breakout, title="Dynamic Support Resistance [Aventra] Breakout", message="Dynamic Support Resistance [Aventra]: Price crossed above the latest resistance level.")
alertcondition(breakdown, title="Dynamic Support Resistance [Aventra] Breakdown", message="Dynamic Support Resistance [Aventra]: Price crossed below the latest support level.")