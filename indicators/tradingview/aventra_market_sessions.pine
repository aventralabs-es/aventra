//@version=6
// Aventra Version: 1.1.3
indicator("Market Sessions [Aventra]", shorttitle="Market Sessions [Aventra]", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

session_timezone = input.string("Europe/Paris", "Session Timezone", options=["Etc/UTC", "America/New_York", "Europe/London", "Europe/Madrid", "Europe/Istanbul", "Europe/Paris", "Asia/Tokyo", "Asia/Hong_Kong"])
show_only_intraday = input.bool(true, "Show Only Intraday")
show_intraday_warning = input.bool(true, "Show Intraday Warning")
show_asia = input.bool(true, "Show Asia Session")
show_london = input.bool(true, "Show London Session")
show_new_york = input.bool(true, "Show New York Session")
asia_session = input.session("0200-1100", "Asia Session")
london_session = input.session("0900-1800", "London Session")
new_york_session = input.session("1400-2300", "New York Session")
maximum_sessions = input.int(50, "Maximum Sessions", minval=0, maxval=200)
show_high_low = input.bool(true, "Show High / Low")
show_high_low_labels = input.bool(false, "Show High / Low Labels")
show_session_labels = input.bool(true, "Show Session Labels")
asia_color = input.color(color.new(color.teal, 80), "Asia Session Color")
london_color = input.color(color.new(color.orange, 80), "London Session Color")
new_york_color = input.color(color.new(color.blue, 80), "New York Session Color")
high_line_color = input.color(color.new(color.gray, 35), "High Line Color")
low_line_color = input.color(color.new(color.gray, 35), "Low Line Color")
label_color = input.color(color.new(color.black, 50), "Label Color")

var table intraday_warning_table = table.new(position.top_right, 1, 1)

var array<box> asia_boxes = array.new<box>()
var array<line> asia_high_lines = array.new<line>()
var array<line> asia_low_lines = array.new<line>()
var array<label> asia_labels = array.new<label>()
var array<label> asia_high_labels = array.new<label>()
var array<label> asia_low_labels = array.new<label>()

var array<box> london_boxes = array.new<box>()
var array<line> london_high_lines = array.new<line>()
var array<line> london_low_lines = array.new<line>()
var array<label> london_labels = array.new<label>()
var array<label> london_high_labels = array.new<label>()
var array<label> london_low_labels = array.new<label>()

var array<box> new_york_boxes = array.new<box>()
var array<line> new_york_high_lines = array.new<line>()
var array<line> new_york_low_lines = array.new<line>()
var array<label> new_york_labels = array.new<label>()
var array<label> new_york_high_labels = array.new<label>()
var array<label> new_york_low_labels = array.new<label>()

safe_delete_box(box _box) =>
    if not na(_box)
        box.delete(_box)

safe_delete_line(line _line) =>
    if not na(_line)
        line.delete(_line)

safe_delete_label(label _label) =>
    if not na(_label)
        label.delete(_label)

trim_sessions(array<box> _boxes, array<line> _high_lines, array<line> _low_lines, array<label> _labels, array<label> _high_labels, array<label> _low_labels) =>
    while array.size(_boxes) > maximum_sessions
        safe_delete_box(array.shift(_boxes))
        safe_delete_line(array.shift(_high_lines))
        safe_delete_line(array.shift(_low_lines))
        safe_delete_label(array.shift(_labels))
        safe_delete_label(array.shift(_high_labels))
        safe_delete_label(array.shift(_low_labels))

format_price(float _price) =>
    str.tostring(_price, format.mintick)

session_active(string _session) =>
    not na(time(timeframe.period, _session, session_timezone))

sessions_allowed = not show_only_intraday or timeframe.isintraday
show_intraday_warning_now = show_intraday_warning and show_only_intraday and not timeframe.isintraday
asia_active = sessions_allowed and show_asia and session_active(asia_session)
london_active = sessions_allowed and show_london and session_active(london_session)
new_york_active = sessions_allowed and show_new_york and session_active(new_york_session)

asia_start = asia_active and not asia_active[1]
london_start = london_active and not london_active[1]
new_york_start = new_york_active and not new_york_active[1]

var box asia_box = na
var line asia_high_line = na
var line asia_low_line = na
var label asia_label = na
var label asia_high_label = na
var label asia_low_label = na
var float asia_high = na
var float asia_low = na
var int asia_start_time = na

var box london_box = na
var line london_high_line = na
var line london_low_line = na
var label london_label = na
var label london_high_label = na
var label london_low_label = na
var float london_high = na
var float london_low = na
var int london_start_time = na

var box new_york_box = na
var line new_york_high_line = na
var line new_york_low_line = na
var label new_york_label = na
var label new_york_high_label = na
var label new_york_low_label = na
var float new_york_high = na
var float new_york_low = na
var int new_york_start_time = na

if asia_start
    asia_high := high
    asia_low := low
    asia_start_time := time
    asia_box := box.new(time, asia_high, time_close, asia_low, xloc=xloc.bar_time, border_color=color.new(asia_color, 100), bgcolor=color.new(asia_color, 100), extend=extend.none)
    asia_high_line := line.new(time, asia_high, time_close, asia_high, xloc=xloc.bar_time, extend=extend.none, color=show_high_low ? high_line_color : color.new(high_line_color, 100), width=1, style=line.style_dashed)
    asia_low_line := line.new(time, asia_low, time_close, asia_low, xloc=xloc.bar_time, extend=extend.none, color=show_high_low ? low_line_color : color.new(low_line_color, 100), width=1, style=line.style_dashed)
    asia_label := show_session_labels ? label.new(time, asia_high, "Asia", xloc=xloc.bar_time, style=label.style_label_down, color=label_color, textcolor=color.white, size=size.small) : na
    asia_high_label := show_high_low and show_high_low_labels ? label.new(time_close, asia_high, "Asia High " + format_price(asia_high), xloc=xloc.bar_time, style=label.style_label_left, color=label_color, textcolor=color.white, size=size.tiny) : na
    asia_low_label := show_high_low and show_high_low_labels ? label.new(time_close, asia_low, "Asia Low " + format_price(asia_low), xloc=xloc.bar_time, style=label.style_label_left, color=label_color, textcolor=color.white, size=size.tiny) : na
    array.push(asia_boxes, asia_box)
    array.push(asia_high_lines, asia_high_line)
    array.push(asia_low_lines, asia_low_line)
    array.push(asia_labels, asia_label)
    array.push(asia_high_labels, asia_high_label)
    array.push(asia_low_labels, asia_low_label)
    trim_sessions(asia_boxes, asia_high_lines, asia_low_lines, asia_labels, asia_high_labels, asia_low_labels)

if asia_active and not na(asia_box)
    asia_high := math.max(asia_high, high)
    asia_low := math.min(asia_low, low)
    box.set_top(asia_box, asia_high)
    box.set_bottom(asia_box, asia_low)
    box.set_right(asia_box, time_close)
    box.set_bgcolor(asia_box, color.new(asia_color, 100))
    line.set_y1(asia_high_line, asia_high)
    line.set_y2(asia_high_line, asia_high)
    line.set_x2(asia_high_line, time_close)
    line.set_color(asia_high_line, show_high_low ? high_line_color : color.new(high_line_color, 100))
    line.set_y1(asia_low_line, asia_low)
    line.set_y2(asia_low_line, asia_low)
    line.set_x2(asia_low_line, time_close)
    line.set_color(asia_low_line, show_high_low ? low_line_color : color.new(low_line_color, 100))
    if not na(asia_label)
        label.set_x(asia_label, int(math.round((asia_start_time + time_close) / 2)))
        label.set_y(asia_label, asia_high)
        label.set_color(asia_label, show_session_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(asia_label, show_session_labels ? color.white : color.new(color.white, 100))
    if not na(asia_high_label)
        label.set_x(asia_high_label, time_close)
        label.set_y(asia_high_label, asia_high)
        label.set_text(asia_high_label, "Asia High " + format_price(asia_high))
        label.set_color(asia_high_label, show_high_low and show_high_low_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(asia_high_label, show_high_low and show_high_low_labels ? color.white : color.new(color.white, 100))
    if not na(asia_low_label)
        label.set_x(asia_low_label, time_close)
        label.set_y(asia_low_label, asia_low)
        label.set_text(asia_low_label, "Asia Low " + format_price(asia_low))
        label.set_color(asia_low_label, show_high_low and show_high_low_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(asia_low_label, show_high_low and show_high_low_labels ? color.white : color.new(color.white, 100))

if london_start
    london_high := high
    london_low := low
    london_start_time := time
    london_box := box.new(time, london_high, time_close, london_low, xloc=xloc.bar_time, border_color=color.new(london_color, 100), bgcolor=color.new(london_color, 100), extend=extend.none)
    london_high_line := line.new(time, london_high, time_close, london_high, xloc=xloc.bar_time, extend=extend.none, color=show_high_low ? high_line_color : color.new(high_line_color, 100), width=1, style=line.style_dashed)
    london_low_line := line.new(time, london_low, time_close, london_low, xloc=xloc.bar_time, extend=extend.none, color=show_high_low ? low_line_color : color.new(low_line_color, 100), width=1, style=line.style_dashed)
    london_label := show_session_labels ? label.new(time, london_high, "London", xloc=xloc.bar_time, style=label.style_label_down, color=label_color, textcolor=color.white, size=size.small) : na
    london_high_label := show_high_low and show_high_low_labels ? label.new(time_close, london_high, "London High " + format_price(london_high), xloc=xloc.bar_time, style=label.style_label_left, color=label_color, textcolor=color.white, size=size.tiny) : na
    london_low_label := show_high_low and show_high_low_labels ? label.new(time_close, london_low, "London Low " + format_price(london_low), xloc=xloc.bar_time, style=label.style_label_left, color=label_color, textcolor=color.white, size=size.tiny) : na
    array.push(london_boxes, london_box)
    array.push(london_high_lines, london_high_line)
    array.push(london_low_lines, london_low_line)
    array.push(london_labels, london_label)
    array.push(london_high_labels, london_high_label)
    array.push(london_low_labels, london_low_label)
    trim_sessions(london_boxes, london_high_lines, london_low_lines, london_labels, london_high_labels, london_low_labels)

if london_active and not na(london_box)
    london_high := math.max(london_high, high)
    london_low := math.min(london_low, low)
    box.set_top(london_box, london_high)
    box.set_bottom(london_box, london_low)
    box.set_right(london_box, time_close)
    box.set_bgcolor(london_box, color.new(london_color, 100))
    line.set_y1(london_high_line, london_high)
    line.set_y2(london_high_line, london_high)
    line.set_x2(london_high_line, time_close)
    line.set_color(london_high_line, show_high_low ? high_line_color : color.new(high_line_color, 100))
    line.set_y1(london_low_line, london_low)
    line.set_y2(london_low_line, london_low)
    line.set_x2(london_low_line, time_close)
    line.set_color(london_low_line, show_high_low ? low_line_color : color.new(low_line_color, 100))
    if not na(london_label)
        label.set_x(london_label, int(math.round((london_start_time + time_close) / 2)))
        label.set_y(london_label, london_high)
        label.set_color(london_label, show_session_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(london_label, show_session_labels ? color.white : color.new(color.white, 100))
    if not na(london_high_label)
        label.set_x(london_high_label, time_close)
        label.set_y(london_high_label, london_high)
        label.set_text(london_high_label, "London High " + format_price(london_high))
        label.set_color(london_high_label, show_high_low and show_high_low_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(london_high_label, show_high_low and show_high_low_labels ? color.white : color.new(color.white, 100))
    if not na(london_low_label)
        label.set_x(london_low_label, time_close)
        label.set_y(london_low_label, london_low)
        label.set_text(london_low_label, "London Low " + format_price(london_low))
        label.set_color(london_low_label, show_high_low and show_high_low_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(london_low_label, show_high_low and show_high_low_labels ? color.white : color.new(color.white, 100))

if new_york_start
    new_york_high := high
    new_york_low := low
    new_york_start_time := time
    new_york_box := box.new(time, new_york_high, time_close, new_york_low, xloc=xloc.bar_time, border_color=color.new(new_york_color, 100), bgcolor=color.new(new_york_color, 100), extend=extend.none)
    new_york_high_line := line.new(time, new_york_high, time_close, new_york_high, xloc=xloc.bar_time, extend=extend.none, color=show_high_low ? high_line_color : color.new(high_line_color, 100), width=1, style=line.style_dashed)
    new_york_low_line := line.new(time, new_york_low, time_close, new_york_low, xloc=xloc.bar_time, extend=extend.none, color=show_high_low ? low_line_color : color.new(low_line_color, 100), width=1, style=line.style_dashed)
    new_york_label := show_session_labels ? label.new(time, new_york_high, "New York", xloc=xloc.bar_time, style=label.style_label_down, color=label_color, textcolor=color.white, size=size.small) : na
    new_york_high_label := show_high_low and show_high_low_labels ? label.new(time_close, new_york_high, "New York High " + format_price(new_york_high), xloc=xloc.bar_time, style=label.style_label_left, color=label_color, textcolor=color.white, size=size.tiny) : na
    new_york_low_label := show_high_low and show_high_low_labels ? label.new(time_close, new_york_low, "New York Low " + format_price(new_york_low), xloc=xloc.bar_time, style=label.style_label_left, color=label_color, textcolor=color.white, size=size.tiny) : na
    array.push(new_york_boxes, new_york_box)
    array.push(new_york_high_lines, new_york_high_line)
    array.push(new_york_low_lines, new_york_low_line)
    array.push(new_york_labels, new_york_label)
    array.push(new_york_high_labels, new_york_high_label)
    array.push(new_york_low_labels, new_york_low_label)
    trim_sessions(new_york_boxes, new_york_high_lines, new_york_low_lines, new_york_labels, new_york_high_labels, new_york_low_labels)

if new_york_active and not na(new_york_box)
    new_york_high := math.max(new_york_high, high)
    new_york_low := math.min(new_york_low, low)
    box.set_top(new_york_box, new_york_high)
    box.set_bottom(new_york_box, new_york_low)
    box.set_right(new_york_box, time_close)
    box.set_bgcolor(new_york_box, color.new(new_york_color, 100))
    line.set_y1(new_york_high_line, new_york_high)
    line.set_y2(new_york_high_line, new_york_high)
    line.set_x2(new_york_high_line, time_close)
    line.set_color(new_york_high_line, show_high_low ? high_line_color : color.new(high_line_color, 100))
    line.set_y1(new_york_low_line, new_york_low)
    line.set_y2(new_york_low_line, new_york_low)
    line.set_x2(new_york_low_line, time_close)
    line.set_color(new_york_low_line, show_high_low ? low_line_color : color.new(low_line_color, 100))
    if not na(new_york_label)
        label.set_x(new_york_label, int(math.round((new_york_start_time + time_close) / 2)))
        label.set_y(new_york_label, new_york_high)
        label.set_color(new_york_label, show_session_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(new_york_label, show_session_labels ? color.white : color.new(color.white, 100))
    if not na(new_york_high_label)
        label.set_x(new_york_high_label, time_close)
        label.set_y(new_york_high_label, new_york_high)
        label.set_text(new_york_high_label, "New York High " + format_price(new_york_high))
        label.set_color(new_york_high_label, show_high_low and show_high_low_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(new_york_high_label, show_high_low and show_high_low_labels ? color.white : color.new(color.white, 100))
    if not na(new_york_low_label)
        label.set_x(new_york_low_label, time_close)
        label.set_y(new_york_low_label, new_york_low)
        label.set_text(new_york_low_label, "New York Low " + format_price(new_york_low))
        label.set_color(new_york_low_label, show_high_low and show_high_low_labels ? label_color : color.new(label_color, 100))
        label.set_textcolor(new_york_low_label, show_high_low and show_high_low_labels ? color.white : color.new(color.white, 100))

asia_started_alert = asia_start
london_started_alert = london_start
new_york_started_alert = new_york_start

bgcolor(asia_active ? asia_color : na)
bgcolor(london_active ? london_color : na)
bgcolor(new_york_active ? new_york_color : na)

if barstate.islast
    table.cell(intraday_warning_table, 0, 0, show_intraday_warning_now ? "Market sessions are hidden on non-intraday charts.\nUse an intraday timeframe or disable Show Only Intraday." : "", text_color=show_intraday_warning_now ? color.white : color.new(color.white, 100), bgcolor=show_intraday_warning_now ? color.new(color.orange, 15) : color.new(color.black, 100), text_size=size.small)

alertcondition(asia_started_alert, title="Market Sessions [Aventra] Asia Session Started", message="Market Sessions [Aventra]: Asia session started.")
alertcondition(london_started_alert, title="Market Sessions [Aventra] London Session Started", message="Market Sessions [Aventra]: London session started.")
alertcondition(new_york_started_alert, title="Market Sessions [Aventra] New York Session Started", message="Market Sessions [Aventra]: New York session started.")
