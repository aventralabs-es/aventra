//@version=6
// Aventra Version: 1.0.1
indicator("Trend Pullback Signals [Aventra]", shorttitle="Trend Pullback Signals [Aventra]", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=200, max_bars_back=5000)

calculation_timeframe = input.timeframe("", "Calculation Timeframe")
signal_direction = input.string("Both", "Signal Direction", options=["Both", "Bullish Only", "Bearish Only"])
trend_ma_length = input.int(55, "Trend MA Length", minval=1)
trend_ma_type = input.string("EMA", "Trend MA Type", options=["EMA", "SMA"])
pullback_ma_length = input.int(21, "Pullback MA Length", minval=1)
pullback_ma_type = input.string("EMA", "Pullback MA Type", options=["EMA", "SMA"])
trend_slope_bars = input.int(5, "Trend Slope Bars", minval=1, maxval=100)
pullback_window_bars = input.int(10, "Pullback Window Bars", minval=1, maxval=200)
atr_length = input.int(14, "ATR Length", minval=1)
pullback_tolerance_atr = input.float(0.25, "Pullback Tolerance ATR", minval=0.0, step=0.01)
confirmation_buffer_atr = input.float(0.05, "Confirmation Buffer ATR", minval=0.0, step=0.01)
confirmation_mode = input.string("Balanced", "Confirmation Mode", options=["Aggressive", "Balanced", "Conservative"])
use_volume_filter = input.bool(true, "Use Volume Filter")
volume_ma_length = input.int(21, "Volume MA Length", minval=1)
minimum_relative_volume = input.float(1.20, "Minimum Relative Volume", minval=0.0, step=0.05)
use_rsi_filter = input.bool(true, "Use RSI Filter")
rsi_length = input.int(14, "RSI Length", minval=1)
bullish_rsi_min = input.float(50.0, "Bullish RSI Minimum", minval=0.0, maxval=100.0, step=0.5)
bearish_rsi_max = input.float(50.0, "Bearish RSI Maximum", minval=0.0, maxval=100.0, step=0.5)
show_signal_markers = input.bool(true, "Show Signal Markers")
show_signal_labels = input.bool(true, "Show Signal Labels")
show_pullback_lines = input.bool(true, "Show Pullback Lines")
show_pullback_zones = input.bool(true, "Show Pullback Zones")
keep_signals = input.bool(true, "Keep Signals")
maximum_signals = input.int(100, "Maximum Signals", minval=1, maxval=250)
signal_label_offset_atr = input.float(0.35, "Signal Label Offset ATR", minval=0.0, step=0.05)
show_trend_ma = input.bool(true, "Show Trend MA")
show_pullback_ma = input.bool(true, "Show Pullback MA")
trend_ma_color = input.color(color.new(color.rgb(33, 150, 243), 30), "Trend MA Color")
pullback_ma_color = input.color(color.new(color.orange, 40), "Pullback MA Color")
bullish_signal_color = input.color(color.new(color.lime, 50), "Bullish Signal Color")
bearish_signal_color = input.color(color.new(color.red, 50), "Bearish Signal Color")
bullish_zone_color = input.color(color.new(color.teal, 90), "Bullish Pullback Zone Color")
bearish_zone_color = input.color(color.new(color.orange, 90), "Bearish Pullback Zone Color")

use_chart_timeframe = calculation_timeframe == ""
request_timeframe = use_chart_timeframe ? timeframe.period : calculation_timeframe

calc_ma(float _source, int _length, string _type) =>
    _type == "EMA" ? ta.ema(_source, _length) : ta.sma(_source, _length)

calc_trend_pullback_source() =>
    float trend_ma = calc_ma(close, trend_ma_length, trend_ma_type)
    float pullback_ma = calc_ma(close, pullback_ma_length, pullback_ma_type)
    float atr_value = ta.atr(atr_length)
    float tolerance = atr_value * pullback_tolerance_atr
    float confirmation_buffer = atr_value * confirmation_buffer_atr
    float volume_ma = ta.sma(volume, volume_ma_length)
    float relative_volume = not na(volume_ma) and volume_ma != 0 ? volume / volume_ma : na
    float rsi_value = ta.rsi(close, rsi_length)
    bool volume_ok = not use_volume_filter or (not na(relative_volume) and relative_volume >= minimum_relative_volume)
    bool bullish_rsi_ok = not use_rsi_filter or (not na(rsi_value) and rsi_value >= bullish_rsi_min)
    bool bearish_rsi_ok = not use_rsi_filter or (not na(rsi_value) and rsi_value <= bearish_rsi_max)
    bool trend_bullish = not na(trend_ma) and close > trend_ma and trend_ma >= trend_ma[trend_slope_bars]
    bool trend_bearish = not na(trend_ma) and close < trend_ma and trend_ma <= trend_ma[trend_slope_bars]
    bool bullish_pullback_touch = trend_bullish and not na(pullback_ma) and low <= pullback_ma + tolerance and close >= trend_ma
    bool bearish_pullback_touch = trend_bearish and not na(pullback_ma) and high >= pullback_ma - tolerance and close <= trend_ma
    var bool bullish_pending = false
    var bool bearish_pending = false
    var float bullish_pullback_level = na
    var float bearish_pullback_level = na
    var float bullish_zone_top = na
    var float bullish_zone_bottom = na
    var float bearish_zone_top = na
    var float bearish_zone_bottom = na
    var int bullish_pullback_time = na
    var int bearish_pullback_time = na
    var int bullish_pullback_bar = na
    var int bearish_pullback_bar = na

    if bullish_pullback_touch
        bullish_pending := true
        bearish_pending := false
        bullish_pullback_level := pullback_ma
        bullish_zone_top := pullback_ma + tolerance
        bullish_zone_bottom := pullback_ma - tolerance
        bullish_pullback_time := time
        bullish_pullback_bar := bar_index

    if bearish_pullback_touch
        bearish_pending := true
        bullish_pending := false
        bearish_pullback_level := pullback_ma
        bearish_zone_top := pullback_ma + tolerance
        bearish_zone_bottom := pullback_ma - tolerance
        bearish_pullback_time := time
        bearish_pullback_bar := bar_index

    bool bullish_expired = bullish_pending and bar_index - bullish_pullback_bar > pullback_window_bars
    bool bearish_expired = bearish_pending and bar_index - bearish_pullback_bar > pullback_window_bars

    if bullish_expired or not trend_bullish
        bullish_pending := false

    if bearish_expired or not trend_bearish
        bearish_pending := false

    bool bullish_aggressive = close > open and close > pullback_ma
    bool bearish_aggressive = close < open and close < pullback_ma
    bool bullish_balanced = close > high[1] + confirmation_buffer and close > pullback_ma
    bool bearish_balanced = close < low[1] - confirmation_buffer and close < pullback_ma
    bool bullish_conservative = bullish_balanced and close > open and close > close[1]
    bool bearish_conservative = bearish_balanced and close < open and close < close[1]
    bool bullish_confirmation = confirmation_mode == "Aggressive" ? bullish_aggressive : confirmation_mode == "Balanced" ? bullish_balanced : bullish_conservative
    bool bearish_confirmation = confirmation_mode == "Aggressive" ? bearish_aggressive : confirmation_mode == "Balanced" ? bearish_balanced : bearish_conservative
    bool bullish_signal = bullish_pending and bullish_confirmation and volume_ok and bullish_rsi_ok
    bool bearish_signal = bearish_pending and bearish_confirmation and volume_ok and bearish_rsi_ok

    if bullish_signal
        bullish_pending := false

    if bearish_signal
        bearish_pending := false

    [bullish_signal, bearish_signal, trend_ma, pullback_ma, bullish_pullback_level, bearish_pullback_level, bullish_zone_top, bullish_zone_bottom, bearish_zone_top, bearish_zone_bottom, bullish_pullback_time, bearish_pullback_time, time, time_close, atr_value, relative_volume, rsi_value]

[bullish_signal_chart, bearish_signal_chart, trend_ma_chart, pullback_ma_chart, bullish_level_chart, bearish_level_chart, bullish_zone_top_chart, bullish_zone_bottom_chart, bearish_zone_top_chart, bearish_zone_bottom_chart, bullish_pullback_time_chart, bearish_pullback_time_chart, source_time_chart, source_time_close_chart, atr_chart, relative_volume_chart, rsi_chart] = calc_trend_pullback_source()
[bullish_signal_tf, bearish_signal_tf, trend_ma_tf, pullback_ma_tf, bullish_level_tf, bearish_level_tf, bullish_zone_top_tf, bullish_zone_bottom_tf, bearish_zone_top_tf, bearish_zone_bottom_tf, bullish_pullback_time_tf, bearish_pullback_time_tf, source_time_tf, source_time_close_tf, atr_tf, relative_volume_tf, rsi_tf] = request.security(syminfo.tickerid, request_timeframe, calc_trend_pullback_source(), barmerge.gaps_off, barmerge.lookahead_off)

bool bullish_signal_raw = use_chart_timeframe ? bullish_signal_chart : bullish_signal_tf
bool bearish_signal_raw = use_chart_timeframe ? bearish_signal_chart : bearish_signal_tf
float trend_ma_value = use_chart_timeframe ? trend_ma_chart : trend_ma_tf
float pullback_ma_value = use_chart_timeframe ? pullback_ma_chart : pullback_ma_tf
float bullish_level = use_chart_timeframe ? bullish_level_chart : bullish_level_tf
float bearish_level = use_chart_timeframe ? bearish_level_chart : bearish_level_tf
float bullish_zone_top = use_chart_timeframe ? bullish_zone_top_chart : bullish_zone_top_tf
float bullish_zone_bottom = use_chart_timeframe ? bullish_zone_bottom_chart : bullish_zone_bottom_tf
float bearish_zone_top = use_chart_timeframe ? bearish_zone_top_chart : bearish_zone_top_tf
float bearish_zone_bottom = use_chart_timeframe ? bearish_zone_bottom_chart : bearish_zone_bottom_tf
int bullish_pullback_time = use_chart_timeframe ? bullish_pullback_time_chart : bullish_pullback_time_tf
int bearish_pullback_time = use_chart_timeframe ? bearish_pullback_time_chart : bearish_pullback_time_tf
int source_time = use_chart_timeframe ? source_time_chart : source_time_tf
float source_atr = use_chart_timeframe ? atr_chart : atr_tf
float source_relative_volume = use_chart_timeframe ? relative_volume_chart : relative_volume_tf
float source_rsi = use_chart_timeframe ? rsi_chart : rsi_tf

plot(show_trend_ma ? trend_ma_value : na, title="Trend MA", color=trend_ma_color, linewidth=2)
plot(show_pullback_ma ? pullback_ma_value : na, title="Pullback MA", color=pullback_ma_color, linewidth=1)

var int last_bullish_signal_time = na
var int last_bearish_signal_time = na
var array<line> signal_lines = array.new<line>()
var array<box> signal_boxes = array.new<box>()
var array<label> signal_markers = array.new<label>()
var array<label> signal_labels = array.new<label>()

safe_delete_line(line _line) =>
    if not na(_line)
        line.delete(_line)

safe_delete_box(box _box) =>
    if not na(_box)
        box.delete(_box)

safe_delete_label(label _label) =>
    if not na(_label)
        label.delete(_label)

clear_signals() =>
    while array.size(signal_lines) > 0
        safe_delete_line(array.shift(signal_lines))
    while array.size(signal_boxes) > 0
        safe_delete_box(array.shift(signal_boxes))
    while array.size(signal_markers) > 0
        safe_delete_label(array.shift(signal_markers))
    while array.size(signal_labels) > 0
        safe_delete_label(array.shift(signal_labels))

trim_signals() =>
    while array.size(signal_lines) > maximum_signals
        safe_delete_line(array.shift(signal_lines))
    while array.size(signal_boxes) > maximum_signals
        safe_delete_box(array.shift(signal_boxes))
    while array.size(signal_markers) > maximum_signals
        safe_delete_label(array.shift(signal_markers))
    while array.size(signal_labels) > maximum_signals
        safe_delete_label(array.shift(signal_labels))

add_signal(int _pullback_time, int _signal_time, float _level, float _zone_top, float _zone_bottom, float _atr, float _relative_volume, float _rsi, bool _bullish) =>
    if not keep_signals
        clear_signals()
    color signal_color = _bullish ? bullish_signal_color : bearish_signal_color
    color zone_color = _bullish ? bullish_zone_color : bearish_zone_color
    string base_text = _bullish ? "Bullish Trend Pullback" : "Bearish Trend Pullback"
    string rel_vol_text = use_volume_filter and not na(_relative_volume) ? " | Rel Vol " + str.tostring(_relative_volume, "#.##") + "x" : ""
    string rsi_text = use_rsi_filter and not na(_rsi) ? " | RSI " + str.tostring(_rsi, "#.#") : ""
    string label_text = base_text + rel_vol_text + rsi_text
    line pullback_line = show_pullback_lines and not na(_pullback_time) and not na(_signal_time) and not na(_level) ? line.new(_pullback_time, _level, _signal_time, _level, xloc=xloc.bar_time, extend=extend.none, color=signal_color, width=2, style=line.style_solid) : na
    box pullback_box = show_pullback_zones and not na(_pullback_time) and not na(_signal_time) and not na(_zone_top) and not na(_zone_bottom) ? box.new(_pullback_time, _zone_top, _signal_time, _zone_bottom, xloc=xloc.bar_time, border_color=color.new(zone_color, 100), bgcolor=zone_color) : na
    label marker = show_signal_markers and not na(_signal_time) and not na(_level) ? label.new(_signal_time, _level, "", xloc=xloc.bar_time, style=_bullish ? label.style_triangleup : label.style_triangledown, color=signal_color, textcolor=signal_color, size=size.tiny) : na
    float label_offset = _atr * signal_label_offset_atr
    float label_y = _bullish ? _level - label_offset : _level + label_offset
    label signal_label = show_signal_labels and not na(_signal_time) and not na(_level) ? label.new(_signal_time, label_y, label_text, xloc=xloc.bar_time, style=_bullish ? label.style_label_up : label.style_label_down, color=color.new(signal_color, 100), textcolor=signal_color, size=size.small) : na
    array.push(signal_lines, pullback_line)
    array.push(signal_boxes, pullback_box)
    array.push(signal_markers, marker)
    array.push(signal_labels, signal_label)
    trim_signals()

bool allow_bullish = signal_direction == "Both" or signal_direction == "Bullish Only"
bool allow_bearish = signal_direction == "Both" or signal_direction == "Bearish Only"
bool both_signals = bullish_signal_raw and bearish_signal_raw
bool prefer_bullish = both_signals ? close > open : bullish_signal_raw
bool prefer_bearish = both_signals ? close <= open : bearish_signal_raw
bool bullish_candidate = allow_bullish and bullish_signal_raw and (not both_signals or prefer_bullish) and (na(last_bullish_signal_time) or source_time != last_bullish_signal_time)
bool bearish_candidate = allow_bearish and bearish_signal_raw and (not both_signals or prefer_bearish) and (na(last_bearish_signal_time) or source_time != last_bearish_signal_time)

if bullish_candidate
    add_signal(bullish_pullback_time, source_time, bullish_level, bullish_zone_top, bullish_zone_bottom, source_atr, source_relative_volume, source_rsi, true)
    last_bullish_signal_time := source_time

if bearish_candidate
    add_signal(bearish_pullback_time, source_time, bearish_level, bearish_zone_top, bearish_zone_bottom, source_atr, source_relative_volume, source_rsi, false)
    last_bearish_signal_time := source_time

alertcondition(bullish_candidate, title="Trend Pullback Signals [Aventra] Bullish Signal", message="Trend Pullback Signals [Aventra]: bullish trend pullback signal detected.")
alertcondition(bearish_candidate, title="Trend Pullback Signals [Aventra] Bearish Signal", message="Trend Pullback Signals [Aventra]: bearish trend pullback signal detected.")
